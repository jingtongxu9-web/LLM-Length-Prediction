# Copy to .env on the server and replace UID/GID with `id -u` and `id -g`.
HOST_UID=1000
HOST_GID=1000

# The collector is single-GPU. The supplied server had idle RTX 4090 devices 4-7
# when inspected; re-check nvidia-smi and select one free device before each run.
GPU_ID=4

# Persistent host paths. Docker never stores models or experiment data in the image.
MODEL_ROOT=/data/Summer_Camp/models
TRACE_ROOT=/data/Summer_Camp/data/interim
RUN_ROOT=/data/Summer_Camp/artifacts/runs
HF_CACHE_ROOT=/data/Summer_Camp/cache/huggingface
